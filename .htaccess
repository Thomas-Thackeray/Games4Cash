Options -Indexes
RewriteEngine On

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# Redirect www to non-www
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^ https://%1%{REQUEST_URI} [R=301,L]

# Serve existing files/dirs directly
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Route /game/123 → game.php?id=123
RewriteRule ^game/([0-9]+)/?$     /game.php?id=$1 [L,QSA]

# Route /platform/167/ps5 → platform.php?id=167&name=ps5
RewriteRule ^platform/([0-9]+)/(.+)/?$ /platform.php?id=$1&name=$2 [L,QSA]

# Route /genre/12/rpg → genre.php?id=12&name=rpg
RewriteRule ^genre/([0-9]+)/(.+)/?$    /genre.php?id=$1&name=$2 [L,QSA]

# Security headers
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Referrer-Policy "strict-origin-when-cross-origin"

    # Cache static assets
    <FilesMatch "\.(css|js|jpg|jpeg|png|svg|woff2|gif|ico)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
</IfModule>

# PHP settings
<IfModule mod_php.c>
    php_value upload_max_filesize 8M
    php_value post_max_size 8M
    php_value max_execution_time 30
    php_flag display_errors Off
</IfModule>
